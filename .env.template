# DataLogicEngine / Universal Knowledge Graph System
# Environment Configuration Template
#
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.template .env
# 2. Fill in all values below with your actual configuration
# 3. NEVER commit .env to version control (it's in .gitignore)
# 4. Generate strong secrets using: python -c "import secrets; print(secrets.token_hex(32))"

# =============================================================================
# SECURITY - REQUIRED
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-replace-me
JWT_SECRET_KEY=your-jwt-secret-key-here-replace-me

# =============================================================================
# APPLICATION
# =============================================================================
FLASK_ENV=development  # Options: development, production, testing
FLASK_DEBUG=False      # Set to True only in development
PORT=5000

# =============================================================================
# DATABASE
# =============================================================================
# SQLite (Development):
DATABASE_URL=sqlite:///ukg_database.db

# PostgreSQL (Production - recommended):
# DATABASE_URL=postgresql://username:password@localhost:5432/ukg_database

# PostgreSQL credentials (if not using full URL):
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ukg_database

# =============================================================================
# SECURITY & CORS
# =============================================================================
# Comma-separated list of allowed origins for CORS
# Production example: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Session timeout (in seconds)
SESSION_TIMEOUT=3600  # 1 hour

# =============================================================================
# RATE LIMITING
# =============================================================================
# Redis URL for production rate limiting (recommended)
# REDIS_URL=redis://localhost:6379/0
# Leave empty to use in-memory storage (development only)
REDIS_URL=

# =============================================================================
# OPENAI / AZURE OPENAI
# =============================================================================
OPENAI_API_KEY=
OPENAI_ORG_ID=

# Azure OpenAI (if using Azure instead of OpenAI)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2023-05-15

# =============================================================================
# AZURE SERVICES (Enterprise)
# =============================================================================
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=

# =============================================================================
# UKG SYSTEM CONFIGURATION
# =============================================================================
UKG_MAX_SIMULATION_LAYERS=10
UKG_DEFAULT_CONFIDENCE_THRESHOLD=0.85
UKG_DEFAULT_REFINEMENT_STEPS=12
UKG_ENABLE_QUANTUM_SIMULATION=False

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/ukg.log

# =============================================================================
# ADMIN CREDENTIALS (Development Only - Change Immediately!)
# =============================================================================
# SECURITY WARNING: These are for development/testing only!
# In production:
# 1. Use strong, unique passwords
# 2. Consider storing in a secrets manager
# 3. Force password change on first login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
ADMIN_EMAIL=admin@example.com

# =============================================================================
# WEBHOOK SECRETS (if using webhooks)
# =============================================================================
GITHUB_WEBHOOK_SECRET=
SLACK_WEBHOOK_SECRET=
GITLAB_WEBHOOK_SECRET=
JIRA_WEBHOOK_SECRET=

# =============================================================================
# EMAIL (if implementing password reset)
# =============================================================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@example.com

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================
# Set to True to enable development features
DEV_MODE=False

# Test database (used for automated tests)
TEST_DATABASE_URL=sqlite:///:memory:
